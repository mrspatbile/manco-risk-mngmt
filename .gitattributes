# =============================================
# Jupyter Notebooks
# =============================================
*.ipynb     filter=nbstripout
*.ipynb     diff=nbstripout

# Ignore Jupyter temporary files
.ipynb_checkpoints/     export-ignore

# =============================================
# Python / Virtual Environment
# =============================================
venv/                   export-ignore
.venv/                  export-ignore

# Byte-compiled files
__pycache__/            export-ignore
*.py[cod]               export-ignore

# Environment / secrets
.env                    export-ignore
*.env                   export-ignore

# OS / Editor files
.DS_Store               export-ignore
Thumbs.db               export-ignore